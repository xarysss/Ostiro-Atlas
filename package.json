{
  "name": "ostiro-atlas",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @ostiro/desktop dev",
    "desktop:dev": "pnpm --filter @ostiro/desktop tauri dev",
    "desktop:build": "pnpm --filter @ostiro/desktop tauri build",
    "installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean"
  }
}
