{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ostiro Atlas",
  "version": "0.3.0",
  "identifier": "fr.ostiro.atlas",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ostiro Atlas",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#0b0b14"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Ostiro",
    "category": "Finance",
    "shortDescription": "Toute votre vie financière, enfin cartographiée.",
    "longDescription": "Application locale et open source de suivi patrimonial centrée sur la fiabilité des données.",
    "copyright": "Copyright 2026 Ostiro contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
